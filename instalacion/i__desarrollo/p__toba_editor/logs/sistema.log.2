SELECT
	puntos_control.objeto, 
	puntos_control.proyecto, 
	puntos_control.pto_control, 
	puntos_control.evento_id
FROM
	apex_ptos_control_x_evento as puntos_control
WHERE
	(puntos_control.proyecto, puntos_control.evento_id) IN (
		SELECT
			proyecto, 
			evento_id
		FROM
			apex_objeto_eventos as eventos
		WHERE
			(eventos.proyecto, eventos.objeto) IN (
				SELECT
					proyecto, 
					objeto
				FROM
					apex_objeto as base
				WHERE
					base.proyecto = 'toba_referencia' AND
					base.objeto = '1000175' ) )

