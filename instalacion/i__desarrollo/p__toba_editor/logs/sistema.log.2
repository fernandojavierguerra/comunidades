	efs.objeto_ei_formulario_proyecto, 
	efs.objeto_ei_formulario, 
	efs.objeto_ei_formulario_fila, 
	efs.identificador, 
	efs.elemento_formulario, 
	efs.columnas, 
	efs.obligatorio, 
	efs.inicializacion, 
	efs.orden, 
	efs.etiqueta, 
	efs.descripcion, 
	efs.colapsado, 
	efs.desactivado, 
	efs.estilo, 
	efs.total, 
	efs.etiqueta_estilo, 
	efs.popup_carga_desc_metodo, 
	efs.popup_carga_desc_clase, 
	efs.popup_carga_desc_include, 
	efs.popup_puede_borrar_estado, 
	efs.estado_defecto, 
	efs.solo_lectura, 
	efs.carga_metodo, 
	efs.carga_clase, 
	efs.carga_include, 
	efs.carga_col_clave, 
	efs.carga_col_desc, 
	efs.carga_sql, 
	efs.carga_fuente, 
	efs.carga_lista, 
	efs.carga_maestros, 
	efs.carga_cascada_relaj, 
	efs.carga_no_seteado, 
	efs.edit_tamano, 
	efs.edit_maximo, 
	efs.edit_mascara, 
	efs.edit_unidad, 
	efs.edit_rango, 
	efs.edit_filas, 
	efs.edit_columnas, 
	efs.edit_wrap, 
	efs.edit_resaltar, 
	efs.edit_ajustable, 
	efs.popup_item, 
	efs.popup_proyecto, 
	efs.popup_editable, 
	efs.popup_ventana, 
	efs.fieldset_fin, 
	efs.check_valor_si, 
	efs.check_valor_no, 
	efs.check_desc_si, 
	efs.check_desc_no, 
	efs.fijo_sin_estado, 
	efs.editor_ancho, 
	efs.editor_alto, 
	efs.editor_botonera, 
	efs.selec_cant_minima, 
	efs.selec_cant_maxima, 
	efs.selec_utilidades, 
	efs.selec_tamano, 
	efs.selec_serializar, 
	efs.edit_confirmar_clave, 
	efs.upload_extensiones, 
	efs.selec_ancho, 
	efs.oculto_relaja_obligatorio, 
	efs.carga_dt, 
	efs.carga_no_seteado_ocultar, 
	efs.carga_consulta_php, 
	efs.edit_expreg, 
	efs.check_ml_toggle, 
	efs.selec_cant_columnas, 
	efs.deshabilitar_rest_func, 
	efs.permitir_html, 
	efs.carga_permite_no_seteado, 
	efs.solo_lectura_modificacion, 
	efs.cascada_mantiene_estado, 
	efs.punto_montaje, 
	efs.placeholder
FROM
	apex_objeto_ei_formulario_ef as efs
WHERE
	(efs.objeto_ei_formulario_proyecto, efs.objeto_ei_formulario) IN (
		SELECT
			objeto_ut_formulario_proyecto, 
			objeto_ut_formulario
		FROM
			apex_objeto_ut_formulario as prop_basicas
		WHERE
			(prop_basicas.objeto_ut_formulario_proyecto, prop_basicas.objeto_ut_formulario) IN (
				SELECT
					proyecto, 
					objeto
				FROM
					apex_objeto as base
				WHERE
					base.proyecto = 'toba_referencia' AND
					base.objeto = '1000175' ) )

