SELECT
	prop_basicas.proyecto, 
	prop_basicas.objeto, 
	prop_basicas.clave, 
	prop_basicas.ap, 
	prop_basicas.ap_clase, 
	prop_basicas.ap_archivo, 
	prop_basicas.sinc_susp_constraints, 
	prop_basicas.sinc_orden_automatico, 
	prop_basicas.debug, 
	prop_basicas.punto_montaje, 
	prop_basicas.sinc_lock_optimista
FROM
	apex_objeto_datos_rel as prop_basicas
WHERE
	(prop_basicas.proyecto, prop_basicas.objeto) IN (
		SELECT
			proyecto, 
			objeto
		FROM
			apex_objeto as base
		WHERE
			base.proyecto = 'comunidades' AND
			base.objeto = '2499' )

