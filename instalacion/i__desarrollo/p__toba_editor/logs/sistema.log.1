 VALUES ('0', '1', 'comunidades', '42', 'personas', '1', '1', DEFAULT, '0', 'id_persona', 'datos_tabla', 'SELECT
	t_p.id_persona,
	t_c.comunidad as id_comunidad_nombre,
	t_p.nombres,
	t_p.apellido,
	t_p.nrodocumento,
	t_p.fechanacimiento,
	t_p.direccion,
	t_b.barrio as id_barrio_nombre,
	t_t.tipodocumento as id_tipodocumento_nombre,
	t_p.nrotelcelular,
	t_p.nrotelfijo,
	t_p.estado,
	t_p.fechaingreso,
	t_p.email,
	t_p.grupo_sanguineo,
	t_p.factor_rh,
	t_p.vacuna_antitetanica
FROM
	personas as t_p	LEFT OUTER JOIN barrios as t_b ON (t_p.id_barrio = t_b.id_barrio)
	LEFT OUTER JOIN tiposdocumento as t_t ON (t_p.id_tipodocumento = t_t.id_tipodocumento),
	comunidades as t_c
WHERE
		t_p.id_comunidad = t_c.id_comunidad
ORDER BY nombres', DEFAULT, DEFAULT, DEFAULT, DEFAULT, DEFAULT, DEFAULT);
