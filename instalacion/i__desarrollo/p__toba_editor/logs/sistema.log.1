SELECT
	esquemas.proyecto, 
	esquemas.fuente_datos, 
	esquemas.nombre, 
	esquemas.principal
FROM
	apex_fuente_datos_schemas as esquemas
WHERE
	(esquemas.proyecto, esquemas.fuente_datos) IN (
		SELECT
			proyecto, 
			fuente_datos
		FROM
			apex_fuente_datos as fuente
