class dt_personas extends toba_datos_tabla
{
	function get_persona_nombre($id_persona)
	{
		/*
		//print_r($id_persona);
		
		$sql = "SELECT apellido ||\', \'|| nombres as persona_nombre FROM personas WHERE id_persona = {$id_persona}";
